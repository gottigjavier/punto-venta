# ===================================================
# Punto de Venta - Environment Configuration
# ===================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ===================================================

# ===== Database =====
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/punto_venta_dev

# ===== JWT Authentication =====
# Access token secret (minimum 32 characters)
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars
# Refresh token secret (minimum 32 characters)
JWT_REFRESH_SECRET=change-this-to-another-secure-random-string-min-32

# ===== Server =====
# Environment: development | staging | production
NODE_ENV=development
# API server port
API_PORT=3001

# ===== Frontend =====
# Frontend URL for CORS (include protocol and port)
FRONTEND_URL=http://localhost:3000

# ===== Rate Limiting =====
# Time window in milliseconds (default: 1 hour = 3600000)
RATE_LIMIT_WINDOW_MS=3600000
# Max requests per window for login (default: 10)
RATE_LIMIT_MAX_REQUESTS=10

# ===== Account Lockout =====
# Max failed login attempts before lockout (default: 3)
MAX_LOGIN_ATTEMPTS=3
# Lockout duration in minutes (default: 30)
LOCKOUT_DURATION_MINUTES=30

# ===== Logging =====
# Log level: error | warn | info | debug | trace (default: info)
LOG_LEVEL=info
